# ============================================
# Worker Enrolit - Environment Variables
# ============================================

# Application
NODE_ENV=production
WORKER_MODE=true

# AWS Configuration
AWS_REGION=eu-west-1
SQS_ENABLED=true
SQS_TRANSACTIONS_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/123456789/tickets-platform-poc-transactions
SQS_NOTIFICATIONS_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/123456789/tickets-platform-poc-notifications

# Database Configuration
DB_HOST=localhost
DB_USER=dbadmin
DB_PASSWORD=your_password_here
DB_NAME=appdb
DB_PORT=3306

# Worker Configuration
WORKER_MAX_MESSAGES=10
WORKER_WAIT_TIME=10
WORKER_VISIBILITY_TIMEOUT=300
WORKER_POLL_INTERVAL=0
